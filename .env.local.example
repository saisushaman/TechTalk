# ----------------------------------------------------------------------------
# REQUIRED — your DEFAULT provider
# Used by every mode except the multi-model benchmark on /eval
# ----------------------------------------------------------------------------

# Options: "openai" | "anthropic"
# "openai" covers any OpenAI-compatible endpoint (Groq, Gemini, OpenRouter, Ollama).
AI_PROVIDER=openai


# Option A — Groq (free, fast, recommended)
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# Option B — Google Gemini
# OPENAI_API_KEY=AIza...
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# OPENAI_MODEL=gemini-2.5-flash-lite

# Option C — OpenAI (paid)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Option D — Anthropic Claude (paid)
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001


# ----------------------------------------------------------------------------
# OPTIONAL — additional providers for multi-model benchmarking on /eval
# Set ONLY the providers whose models you want to benchmark.
# Each one is independent; you can have any combination.
# When you click "Run real benchmark" on /eval, the model name is auto-routed:
#   claude-*   → ANTHROPIC_API_KEY
#   gpt-*, o1-*, o3-* → OPENAI_API_KEY_DIRECT
#   gemini-*   → GEMINI_API_KEY
#   llama-*, mixtral, qwen, deepseek, kimi → GROQ_API_KEY
#   anything else → falls back to your default provider above
# ----------------------------------------------------------------------------

# Direct Anthropic (only needed if your DEFAULT isn't Anthropic AND you want
# to benchmark Claude models on /eval)
# ANTHROPIC_API_KEY=sk-ant-...

# Direct OpenAI (only needed if your DEFAULT isn't OpenAI AND you want to
# benchmark gpt-4o / o1 / o3 models on /eval)
# OPENAI_API_KEY_DIRECT=sk-...

# Google Gemini (only needed if your DEFAULT isn't Gemini AND you want to
# benchmark gemini-* models on /eval)
# GEMINI_API_KEY=AIza...

# Groq (only needed if your DEFAULT isn't Groq AND you want to benchmark
# llama-* / qwen-* etc. on /eval)
# GROQ_API_KEY=gsk_...


# ----------------------------------------------------------------------------
# Optional Whisper override (Listen mode)
# ----------------------------------------------------------------------------
# WHISPER_MODEL=whisper-large-v3-turbo
