# Pick ONE path. Set AI_PROVIDER and the matching key.

# Options: "openai" | "anthropic"
# Note: "openai" also covers any OpenAI-compatible endpoint
# (Gemini, Groq, OpenRouter, Ollama, together.ai) via OPENAI_BASE_URL.
AI_PROVIDER=openai


# =============================================
# Option A — Google Gemini (free, recommended)
# =============================================
# 1. Go to https://aistudio.google.com/app/apikey
# 2. Click "Create API key", copy it
# 3. Uncomment these three lines and paste your key
#
# OPENAI_API_KEY=AIza...
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# OPENAI_MODEL=gemini-2.0-flash
#
# Other good free Gemini models:
#   gemini-2.0-flash-lite   (fastest, lighter)
#   gemini-2.0-flash        (default pick, great quality/speed)
#   gemini-2.5-flash        (newer, better reasoning)
#   gemini-2.5-pro          (smartest; tighter rate limit on free tier)


# =============================================
# Option B — Groq (free, very fast)
# =============================================
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile


# =============================================
# Option C — OpenAI (paid)
# =============================================
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini


# =============================================
# Option D — OpenRouter (mixed free + paid)
# =============================================
# OPENAI_API_KEY=sk-or-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct:free


# =============================================
# Option E — Ollama (local, no key)
# =============================================
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.2


# =============================================
# Option F — Anthropic Claude (paid)
# =============================================
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
